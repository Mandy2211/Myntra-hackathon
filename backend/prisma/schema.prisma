// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         String   @default("CUSTOMER") // CUSTOMER or SELLER
  gender       String   @default("Men")
  city         String   @default("Coimbatore")
  state        String   @default("Tamil Nadu")
  name         String?
  createdAt    DateTime @default(now())
}

model Product {
  id                String   @id
  name              String
  img               String
  asin              String?
  price             Float
  mrp               Float
  rating            Float
  ratingTotal       Int
  discount          String?
  seller            String?
  purl              String?
  gender            String?
  category          String?
  macro_category    String?
  material          String?
  occasion          String?
  season            String?
  climate           String?
  ethnic_style      String?
  price_segment     String?
  weather_priority  Int?
  festival_priority Int?
  confidence        Float?
  purchases   Purchase[]
}

model CityContext {
  id             Int      @id @default(autoincrement())
  cityName       String   @unique
  climate        String   // e.g., humid, moderate, hot, cold
  activeFestival String   // e.g., Pongal, Chhath Puja, Ugadi, etc.
  preferredTags  String[] // tags to priority-sort when this city is selected
}

model Purchase {
  id        String   @id @default(uuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  cityName  String
  createdAt DateTime @default(now())
}
