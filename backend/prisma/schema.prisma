// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         String   @default("CUSTOMER") // CUSTOMER or SELLER
  gender       String   @default("Men")
  city         String   @default("Coimbatore")
  state        String   @default("Tamil Nadu")
  name         String?
  createdAt    DateTime @default(now())
}

model Product {
  id                String   @id
  name              String
  img               String
  asin              String?
  price             Float
  mrp               Float
  rating            Float
  ratingTotal       Int
  discount          String?
  seller            String?
  purl              String?
  gender            String?
  category          String?
  macro_category    String?
  material          String?
  occasion          String?
  season            String?
  climate           String?
  ethnic_style      String?
  price_segment     String?
  weather_priority  Int?
  festival_priority Int?
  confidence        Float?
  purchases   Purchase[]
}

model ProductContext {
  product_id      String  @id
  gender_category String
  category        String
  macro_category  String  @default("Clothing")
  material        String
  occasion        String
  season          String
  climate         String  @default("Neutral")
  product         Product @relation(fields: [product_id], references: [id], onDelete: Cascade)
}

model WeatherCache {
  city         String   @id
  temperature  Float
  weather      String
  last_updated DateTime @default(now())
}

model FestivalCalendar {
  id            Int      @id @default(autoincrement())
  festival_name String
  state         String
  start_date    DateTime
  end_date      DateTime
  type          String   @default("Normal")
}
