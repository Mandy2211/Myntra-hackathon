generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         String   @default("CUSTOMER")
  city         String   @default("Coimbatore")
  state        String   @default("Tamil Nadu")
  name         String?
  createdAt       DateTime @default(now())
  gender          String   @default("Men")
  mobileNumber    String?
  businessType    String?
  businessName    String?
  gstNumber       String?
  yearsInBusiness Int?
  primaryProduct  String?
  pincode         String?
  isBlocked       Boolean  @default(false)

  Products         Product[]
  CategoryRequests CategoryRequest[]
  Reviews          Review[]
  Purchases        Purchase[]
  WarningsSent     SellerWarning[] @relation("AdminWarnings")
  WarningsReceived SellerWarning[] @relation("SellerWarnings")
}


model Product {
  id                String     @id
  name              String
  img               String
  asin              String?
  price             Float
  mrp               Float
  rating            Float
  ratingTotal       Int
  discount          String?
  seller            String?
  purl              String?
  gender            String?
  category          String?
  macro_category    String?
  material          String?
  occasion          String?
  season            String?
  climate           String?
  ethnic_style      String?
  price_segment     String?
  weather_priority  Int?
  festival_priority Int?
  confidence        Float?
  
  sellerId          String?
  city              String?
  state             String?
  pincode           String?
  status            String  @default("Active")
  remainingStock    Int     @default(0)
  source            String  @default("imported")
  
  Seller            User?   @relation(fields: [sellerId], references: [id])
  Purchase          Purchase[]
  Reviews           Review[]
}

model Review {
  id          String   @id @default(uuid())
  userId      String
  productId   String
  purchaseId  String
  rating      Int      @default(5)
  comment     String
  isComplaint Boolean  @default(false)
  createdAt   DateTime @default(now())

  User        User     @relation(fields: [userId], references: [id])
  Product     Product  @relation(fields: [productId], references: [id])
  Purchase    Purchase @relation(fields: [purchaseId], references: [id])
}

model SellerWarning {
  id        String   @id @default(uuid())
  sellerId  String
  adminId   String
  message   String
  type      String   @default("WARNING")
  createdAt DateTime @default(now())

  Seller    User     @relation("SellerWarnings", fields: [sellerId], references: [id])
  Admin     User     @relation("AdminWarnings", fields: [adminId], references: [id])
}

model SearchQuery {
  id        String   @id @default(uuid())
  rawQuery  String
  category  String   @default("NA")
  type      String   @default("NA")
  colour    String   @default("NA")
  material  String   @default("NA")
  gender    String   @default("NA")
  occasion  String   @default("NA")
  budget    String   @default("NA")
  city      String
  state     String
  createdAt DateTime @default(now())
}

model Purchase {
  id              String   @id @default(uuid())
  productId       String
  sellerId        String?
  userId          String?
  quantity        Int      @default(1)
  priceAtPurchase Float    @default(0)
  cityName        String
  stateName       String   @default("Uttar Pradesh")
  createdAt       DateTime @default(now())
  Product         Product  @relation(fields: [productId], references: [id])
  User            User?    @relation(fields: [userId], references: [id])
  Reviews         Review[]
}

model CityContext {
  id             Int      @id @default(autoincrement())
  cityName       String   @unique
  climate        String
  activeFestival String
  preferredTags  String[]
}

model CategoryRequest {
  id             String   @id @default(uuid())
  sellerId       String
  categoryName   String
  gender         String
  isSeasonal     Boolean  @default(false)
  origin         String   @default("Normal")
  description    String
  sampleImageUrl String?
  status         String   @default("Pending")
  createdAt      DateTime @default(now())

  Seller         User     @relation(fields: [sellerId], references: [id])
}
