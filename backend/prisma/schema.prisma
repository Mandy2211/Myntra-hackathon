generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         String   @default("CUSTOMER")
  city         String   @default("Coimbatore")
  state        String   @default("Tamil Nadu")
  name         String?
  createdAt    DateTime @default(now())
  gender       String   @default("Men")
}

model Product {
  id                String     @id
  name              String
  img               String
  asin              String?
  price             Float
  mrp               Float
  rating            Float
  ratingTotal       Int
  discount          String?
  seller            String?
  purl              String?
  gender            String?
  category          String?
  macro_category    String?
  material          String?
  occasion          String?
  season            String?
  climate           String?
  ethnic_style      String?
  price_segment     String?
  weather_priority  Int?
  festival_priority Int?
  confidence        Float?
  Purchase          Purchase[]
}

model Purchase {
  id        String   @id @default(uuid())
  productId String
  cityName  String
  stateName String   @default("Uttar Pradesh")
  createdAt DateTime @default(now())
  Product   Product  @relation(fields: [productId], references: [id])
}

model CityContext {
  id             Int      @id @default(autoincrement())
  cityName       String   @unique
  climate        String
  activeFestival String
  preferredTags  String[]
}
